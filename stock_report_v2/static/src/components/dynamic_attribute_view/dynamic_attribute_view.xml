<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="stock_report_v2.DynamicAttributeView" owl="1">
        <Layout t-props="layoutProps">
            <div class="o_dynamic_attribute_view">
                <div class="o_main_header d-flex align-items-center justify-content-between mb-3">
                    <div>
                        <h2 class="o_page_title m-0">
                            <t t-esc="state.config ? state.config.name : ''"/>
                        </h2>
                        <small t-if="state.config &amp;&amp; state.config.use_forecast" class="text-muted">
                            Showing forecasted quantities
                        </small>
                        <small t-else="" class="text-muted">
                            Showing on-hand quantities
                        </small>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <div class="form-check ms-3 show_img">
                            <input type="checkbox" class="form-check-input"
                                id="showImageCheckbox"
                                t-att-checked="state.config.show_images"
                                t-on-change="onImageCheckboxChange"/>
                            <label class="form-check-label" for="showImageCheckbox">
                                Show Images
                            </label>
                        </div>
                        <div class="form-check ms-3 show_forecasted_qty">
                            <input type="checkbox" class="form-check-input"
                                id="showForecastCheckbox"
                                t-att-checked="state.config.use_forecast"
                                t-on-change="onForecastCheckboxChange"/>
                            <label class="form-check-label" for="showForecastCheckbox">
                                Show Forecasted Qty
                            </label>
                        </div>

                        <div class="o_search_container">
                            <div class="o_search_panel input-group">
                                <input type="text" class="form-control" t-att-value="state.searchInput" t-on-input="onSearchInput" placeholder="Search products..." aria-label="Search products"/>
                                <button class="btn btn-outline-secondary" t-on-click="clearSearch" aria-label="Clear search">
                                    <i class="fa fa-times"/>
                                </button>
                            </div>
                        </div>
                        <div class="ms-2">
                            <select class="form-select" t-on-change="onFilterChange" aria-label="Filter products">
                                <option value="all">All Products</option>
                                <option value="positive">Available (&gt; 0)</option>
                                <option value="negative">Negative Stock (&lt; 0)</option>
                                <option value="zero">Zero Stock (= 0)</option>
                                <option value="reserved">Has Reserved</option>
                                <option value="replenishment">Has Incoming</option>
                                <option value="outgoing">Has Outgoing</option>
                            </select>
                        </div>
                        <button class="btn btn-primary" t-on-click="refreshData" aria-label="Refresh">
                            <i class="fa fa-refresh me-1"/>Refresh
                        </button>
                    </div>
                </div>

                <t t-if="state.loading">
                    <div class="o_loading_screen">
                        <div class="o_spinner_container">
                            <i class="fa fa-spinner fa-spin fa-2x" role="img" aria-label="Loading"/>
                            <div class="o_loading_text mt-2">Loading...</div>
                        </div>
                    </div>
                </t>
                <t t-elif="state.error">
                    <div class="alert alert-danger" role="alert">
                        <t t-esc="state.error"/>
                    </div>
                </t>
                <t t-else="">
                    <div class="o_product_attribute_matrix">
                        <div class="o_matrix_container">
                            <!-- Group products by series -->
                            <t t-set="series_groups" t-value="groupProductsBySeries(state.filteredProducts)"/>
                            
                            <!-- Create a single table for all products -->
                            <table class="table o_list_table o_matrix_table">
                                <thead class="thead-light o_list_view_header">
                                    <tr>
                                        <th t-if="state.config &amp;&amp; state.config.show_images" class="o_image_col" style="width: 120px;">Image</th>
                                        <th class="o_name_col">Product</th>
                                        <t t-if="state.attributes.length > 0 &amp;&amp; state.attributes[0]">
                                            <th class="o_primary_col">
                                                <t t-esc="state.attributes[0].name"/>
                                            </th>
                                        </t>
                                        <th class="o_warehouse_col text-center">Warehouse</th>
                                        <th class="o_location_col text-center">Location</th>
                                        <!-- Get series groups and maximum number of size columns -->
                                        <t t-set="series_groups" t-value="groupProductsBySeries(state.filteredProducts)"/>
                                        <t t-set="max_serie_count" t-value="getMaxSerieValuesCount(series_groups)"/>
                                        <t t-foreach="Array(max_serie_count).fill(0).map((_, i) => i)" t-as="index" t-key="index">
                                            <th class="o_serie_value_col text-center">-</th>
                                        </t>
                                    </tr>
                                </thead>
                                <tbody>
                                    <!-- Iterate through each product group -->
                                    <t t-foreach="series_groups" t-as="serie" t-key="serie.serie_id">
                                        <!-- Size header row for this group -->
                                        <tr class="o_size_header">
                                            <td t-if="state.config &amp;&amp; state.config.show_images" class="p-0"></td>
                                            <td colspan="4" class="p-0"></td>
                                            <!-- Show the actual size values for this group, with placeholders for extra columns -->
                                            <t t-foreach="Array(max_serie_count).fill(0).map((_, i) => i)" t-as="index" t-key="index">
                                                <td class="text-center fw-bold">
                                                    <t t-if="index &lt; serie.serie_values.length">
                                                        <t t-esc="serie.serie_values[index]"/>
                                                    </t>
                                                    <t t-else="">-</t>
                                                </td>
                                            </t>
                                        </tr>
                                        
                                        <!-- Products in this group -->
                                        <!-- <t t-foreach="serie.products" t-as="product" t-key="product.id">
                                            <t t-set="matrix" t-value="_createAttributeMatrix(product)"/>
                                            <t t-set="matrixStock" t-value="_createAttributeMatrixStock(product)"/>
                                            <t t-log="'matrix'"/>
                                            <t t-log="matrix"/>
                                            <t t-log="'matrixStock'"/>
                                            <t t-log="matrixStock"/>
                                            <t t-if="matrix &amp;&amp; matrix.rows.length > 0">
                                                <t t-foreach="matrix.rows" t-as="row" t-key="row.header">
                                                    <tr class="o_matrix_row">
                                                        <t t-if="row_index == 0">
                                                            <td t-if="state.config &amp;&amp; state.config.show_images" class="o_image_cell" t-att-rowspan="matrix.rows.length">
                                                                <img t-att-src="product.image_url || '/stock_report_v2/static/src/img/no-image-found.png'" class="o_product_image" t-att-data-product-id="product.id" style="width: 120px; height: 120px; object-fit: contain;"/>
                                                            </td>
                                                        </t>
                                                        <td class="o_name_cell">
                                                            <a t-att-href="product.product_url" target="_blank" class="fw-medium" t-esc="product.name"/>
                                                        </td>
                                                        <td class="o_primary_value_cell fw-medium">
                                                            <span t-esc="row.header"/>
                                                        </td>
                                                        <td class="o_warehouse_cell text-center">
                                                            <t t-set="variantWithLocation" t-value="row.cells.find(c => c &amp;&amp; c.variant &amp;&amp; (c.variant.warehouse_name || c.variant.location_name))"/>
                                                            <span t-esc="variantWithLocation ? variantWithLocation.variant.warehouse_name : '-'"/>
                                                        </td>
                                                        <td class="o_location_cell text-center">
                                                            <t t-set="variantWithLocation" t-value="row.cells.find(c => c &amp;&amp; c.variant &amp;&amp; (c.variant.warehouse_name || c.variant.location_name))"/>
                                                            <span t-esc="variantWithLocation ? variantWithLocation.variant.location_name : '-'"/>
                                                        </td>
                                        
                                                        <t t-foreach="Array(max_serie_count).fill(0).map((_, i) => i)" t-as="index" t-key="index">
                                                            <td class="o_quantity_cell text-center">
                                                                <t t-if="index &lt; serie.serie_values.length">
                                                                    <t t-set="value" t-value="serie.serie_values[index]"/>
                                                                    <t t-set="cell" t-value="getCellForSerieValue(row, value)"/>
                                                                    <t t-if="cell">
                                                                        <span class="o_quantity" t-att-class="getVariantCellClass(cell)" 
                                                                              t-on-click="() => this.handleCellClick(cell, product.id)" 
                                                                              t-esc="formatQty(cell.qty)"/>
                                                                    </t>
                                                                    <t t-else="">
                                                                        <span class="o_quantity o_no_quantity">-</span>
                                                                    </t>
                                                                </t>
                                                                <t t-else="">
                                                                    <span class="o_quantity o_no_quantity">-</span>
                                                                </t>
                                                            </td>
                                                        </t>
                                                    </tr>
                                                </t>
                                            </t>
                                        </t> -->
                                        <t t-foreach="serie.products" t-as="product" t-key="product.id">
                                            <t t-set="matrix" t-value="_createAttributeMatrixStock(product)"/>
                                            <t t-log="'matrix'"/>
                                            <t t-log="matrix"/>
                                            <t t-if="matrix &amp;&amp; matrix.rows.length > 0">
                                                <t t-foreach="matrix.rows" t-as="row" t-key="row.header + '_' + row.location_id">
                                                    <tr class="o_matrix_row">
                                                        <t t-if="row_index == 0">
                                                            <td t-if="state.config &amp;&amp; state.config.show_images" class="o_image_cell" t-att-rowspan="matrix.rows.length">
                                                                <img t-att-src="product.image_url || '/stock_report_v2/static/src/img/no-image-found.png'" class="o_product_image" t-att-data-product-id="product.id" style="width: 120px; height: 120px; object-fit: contain;"/>
                                                            </td>
                                                        </t>
                                                        <td class="o_name_cell">
                                                            <a t-att-href="product.product_url" target="_blank" class="fw-medium" t-esc="product.name"/>
                                                        </td>
                                                        <td class="o_primary_value_cell fw-medium">
                                                            <span t-esc="row.header"/>
                                                        </td>
                                                        <td class="o_warehouse_cell">
                                                            <span t-esc="row.warehouse_name || '-'"/>
                                                        </td>
                                                        <td class="o_location_cell">
                                                            <span t-esc="row.location_name || '-'"/>
                                                        </td>

                                                        <!-- Display cells for each size column -->
                                                        <t t-foreach="Array(max_serie_count).fill(0).map((_, i) => i)" t-as="index" t-key="index">
                                                            <td class="o_quantity_cell text-center">
                                                                <t t-if="index &lt; serie.serie_values.length">
                                                                    <t t-set="value" t-value="serie.serie_values[index]"/>
                                                                    <t t-set="cell" t-value="getCellForSerieValue(row, value, row.location_id)"/>
                                                                    <t t-if="cell">
                                                                        <span class="o_quantity" t-att-class="getVariantCellClass(cell)" 
                                                                            t-on-click="() => this.handleCellClick(cell, product.id)" 
                                                                            t-esc="formatQty(cell.qty)"/>
                                                                    </t>
                                                                    <t t-else="">
                                                                        <span class="o_quantity o_no_quantity">-</span>
                                                                    </t>
                                                                </t>
                                                                <t t-else="">
                                                                    <span class="o_quantity o_no_quantity">-</span>
                                                                </t>
                                                            </td>
                                                        </t>
                                                    </tr>
                                                </t>
                                            </t>
                                        </t>
                                    </t>
                                </tbody>
                            </table>
                        </div>

                        <div class="o_pagination d-flex justify-content-between align-items-center mt-2">
                            <div class="o_pagination_info">
                                Showing Page: <t t-esc="state.currentPage"/> of <t t-esc="state.totalPages"/>
                            </div>
                            <div class="o_pagination_controls">
                                <ul class="pagination mb-0">
                                    <li class="page-item" t-att-class="state.currentPage == 1 ? 'disabled' : ''">
                                        <a class="page-link" href="#" t-on-click.prevent="prevPage">&#171;</a>
                                    </li>
                                    <li class="page-item active">
                                        <span class="page-link">
                                            <t t-esc="state.currentPage"/>
                                        </span>
                                    </li>
                                    <li class="page-item" t-att-class="state.currentPage == state.totalPages ? 'disabled' : ''">
                                        <a class="page-link" href="#" t-on-click.prevent="nextPage">&#187;</a>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </t>

                <!-- Variant Details Modal -->
                <div t-if="state.showVariantModal" class="modal fade show d-block" tabindex="-1" role="dialog" aria-modal="true">
                    <div class="modal-dialog modal-lg modal-dialog-centered">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title">
                                    <t t-if="state.selectedVariant">
                                        <t t-esc="state.selectedVariant.name"/>
                                    </t>
                                </h5>
                                <button type="button" class="btn-close" aria-label="Close" t-on-click="closeVariantModal"></button>
                            </div>
                            <div class="modal-body">
                                <t t-if="state.selectedVariant">
                                    <div class="row">
                                        <div class="col-md-4">
                                            <img t-att-src="state.selectedVariant.image" class="img-fluid rounded mb-3"/>
                                        </div>
                                        <div class="col-md-8">
                                            <h6 class="mb-3">Stock Information</h6>
                                            <table class="table table-bordered">
                                                <thead class="table-light">
                                                    <tr>
                                                        <th>Stock Type</th>
                                                        <th class="text-center">Quantity</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <tr>
                                                        <td t-if="state.config &amp;&amp; state.config.use_forecast">Forecasted</td>
                                                        <td t-else="">On Hand</td>
                                                        <td class="text-center">
                                                            <td t-esc="formatQty(state.selectedVariant.qty)"></td>
                                                        </td>
                                                    </tr>
                                                    <tr>
                                                        <td>Reserved</td>
                                                        <td t-esc="formatQty(state.selectedVariant.qty_reserved)"></td>
                                                    </tr>
                                                    <tr>
                                                        <td>Incoming</td>
                                                        <td t-esc="formatQty(state.selectedVariant.qty_incoming)"></td>
                                                    </tr>
                                                    <tr>
                                                        <td>Outgoing</td>
                                                        <td t-esc="formatQty(state.selectedVariant.qty_outgoing)"></td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </t>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary me-2" t-on-click="closeVariantModal">Close</button>
                                <t t-if="state.selectedVariant &amp;&amp; state.selectedVariant.product_url">
                                    <a t-att-href="state.selectedVariant.product_url" target="_blank" class="btn btn-primary">View Product</a>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Modal backdrop -->
                <div t-if="state.showVariantModal" class="modal-backdrop fade show"></div>
            </div>
        </Layout>
    </t>
</templates>