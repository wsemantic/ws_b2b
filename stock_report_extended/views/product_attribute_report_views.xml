<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree/List View for Product Attribute Report with stock status colors -->
    <record id="view_product_attribute_report_tree" model="ir.ui.view">
        <field name="name">product.attribute.report.tree</field>
        <field name="model">product.attribute.report</field>
        <field name="arch" type="xml">
            <tree string="Product Attributes by Size and Color" default_order="product_name,attribute_name,attribute_value" 
                  expand="1" create="0" edit="0" delete="0" multi_edit="0" decoration-success="stock_status == 'in_stock'" 
                  decoration-info="stock_status == 'reserved'" decoration-danger="stock_status == 'replenish'" 
                  decoration-muted="stock_status == 'out_of_stock'">
                <field name="product_image" widget="image" options="{'size': [128, 128]}" nolabel="1"/>
                <field name="display_name"/>
                <field name="attribute_name" invisible="0" string="Attribute"/>
                <field name="attribute_value" invisible="0" string="Value"/>
                <field name="attribute_color" invisible="1"/>
                <field name="product_default_code" optional="hide"/>
                <field name="qty_available" sum="Total On Hand" decoration-bf="1" widget="color_qty" options="{'color_field': 'attribute_color'}"/>
                <field name="reserved_qty" sum="Total Reserved" optional="show"/>
                <field name="incoming_qty" sum="Total Incoming" optional="show"/>
                <field name="virtual_available" sum="Total Forecast" optional="hide"/>
                <field name="stock_status" invisible="1"/> <!-- Used for decoration -->
                <field name="product_id" optional="hide"/>
                <field name="product_template_id" optional="hide"/>
                <field name="attribute_id" optional="hide"/>
                <field name="attribute_value_id" optional="hide"/>
                <field name="categ_id" optional="hide"/>
                <field name="uom_id" groups="uom.group_uom" optional="hide"/>
                <field name="company_id" groups="base.group_multi_company" optional="hide"/>
            </tree>
        </field>
    </record>

    <!-- Search View for Product Attribute Report -->
    <record id="view_product_attribute_report_search" model="ir.ui.view">
        <field name="name">product.attribute.report.search</field>
        <field name="model">product.attribute.report</field>
        <field name="arch" type="xml">
            <search string="Product Attributes">
                <field name="product_name" filter_domain="[('product_name', 'ilike', self)]"/>
                <field name="product_default_code" filter_domain="[('product_default_code', 'ilike', self)]"/>
                <field name="attribute_name" filter_domain="[('attribute_name', 'ilike', self)]"/>
                <field name="attribute_value" filter_domain="[('attribute_value', 'ilike', self)]"/>
                <field name="display_name" filter_domain="[('display_name', 'ilike', self)]"/>
                <separator/>
                <filter string="Available Products" name="available" domain="[('qty_available', '>', 0)]"/>
                <filter string="Out of Stock" name="out_of_stock" domain="[('qty_available', '=', 0)]"/>
                <filter string="To Replenish" name="replenish" domain="[('incoming_qty', '>', 0)]"/>
                <filter string="Reserved" name="reserved" domain="[('reserved_qty', '>', 0)]"/>
                <separator/>
                <filter string="Size Attribute" name="size_attribute" domain="[('attribute_name', 'ilike', 'size')]"/>
                <filter string="Color Attribute" name="color_attribute" domain="[('attribute_name', 'ilike', 'color')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter string="Product" name="product" context="{'group_by': 'product_name'}"/>
                    <filter string="Attribute Type" name="attribute" context="{'group_by': 'attribute_name'}"/>
                    <filter string="Attribute Value" name="attribute_value" context="{'group_by': 'attribute_value'}"/>
                    <filter string="Product Category" name="categ_id" context="{'group_by': 'categ_id'}"/>
                    <filter string="Company" name="company" context="{'group_by': 'company_id'}" groups="base.group_multi_company"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Pivot View for Product Attribute Report -->
    <record id="view_product_attribute_report_pivot" model="ir.ui.view">
        <field name="name">product.attribute.report.pivot</field>
        <field name="model">product.attribute.report</field>
        <field name="arch" type="xml">
            <pivot string="Product Attributes" display_quantity="true">
                <field name="product_name" type="row"/>
                <field name="attribute_name" type="row"/>
                <field name="attribute_value" type="col"/>
                <field name="qty_available" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Main Action for Product Attribute Report -->
    <record id="action_product_attribute_report" model="ir.actions.act_window">
        <field name="name">Product Attribute Stock</field>
        <field name="res_model">product.attribute.report</field>
        <field name="view_mode">pivot,tree</field>
        <field name="search_view_id" ref="view_product_attribute_report_search"/>
        <field name="context">{'search_default_available': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No products with attributes found
            </p>
            <p>
                This report shows products grouped by their attributes and values with stock status.
            </p>
        </field>
    </record>

</odoo> 